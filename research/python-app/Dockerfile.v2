# v2: layer-optimized, deps cached separately from code
# Base image includes full Debian userland and Python.
FROM python:3.11-bookworm

# Set working directory for the app.
WORKDIR /app

# Copy dependency manifests first for better cache reuse.
COPY requirements.txt /app/requirements.txt
COPY requirements.lock /app/requirements.lock

# Install pinned dependencies from the lockfile.
RUN pip install --no-cache-dir -r /app/requirements.lock

# Copy application source code last.
COPY . /app
